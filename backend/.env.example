# Copy this file to `.env` and fill in your Aiven PostgreSQL credentials.
# Aiven gives you a connection URI in the service overview page —
# use the "Service URI" field directly.
#
# Format (host/port/password redacted):
#   postgres://avnadmin:<password>@<service-id>.aivencloud.com:<port>/defaultdb?sslmode=require

DATABASE_URL=postgres://avnadmin:REPLACE_PASSWORD@REPLACE_HOST.aivencloud.com:REPLACE_PORT/defaultdb?sslmode=require

# Optional: force the local SQLite database even when DATABASE_URL is present.
# SQLite is auto-created at backend/local.db and imports database/out/*.csv.
# DATABASE_MODE=sqlite

# Optional: disable automatic CSV corpus import.
# LOAD_CORPUS=false
